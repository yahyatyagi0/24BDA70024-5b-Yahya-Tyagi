<div style="background: #fee; border: 2px solid #fcc; border-radius: 5px; padding: 20px; max-width: 600px; margin: 20px auto;">
  <h2 style="color: #c33; margin-bottom: 10px;">❌ An Error Occurred</h2>
  
  <p style="color: #666; margin-bottom: 20px;">
    <strong>Error Message:</strong>
  </p>
  
  <div style="background: white; border-left: 4px solid #c33; padding: 15px; border-radius: 3px; margin-bottom: 20px; font-family: monospace; word-break: break-all;">
    <%= error %>
  </div>

  <p style="color: #666; margin-bottom: 15px;">
    If you believe this is a mistake, please try again or contact support.
  </p>

  <div style="display: flex; gap: 10px;">
    <a href="/" style="padding: 10px 20px; background: #667eea; color: white; border-radius: 5px; text-decoration: none; display: inline-block;">← Go Home</a>
    <a href="javascript:history.back()" style="padding: 10px 20px; background: #95a5a6; color: white; border-radius: 5px; text-decoration: none; display: inline-block;">← Go Back</a>
  </div>
</div>
