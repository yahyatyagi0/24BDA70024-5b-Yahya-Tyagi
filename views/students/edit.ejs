<!DOCTYPE html>
<html>
<head>
    <title>Edit Student</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background-color: #f5f5f5; }
        h1 { color: #333; }
        form { background: white; padding: 20px; border-radius: 5px; max-width: 400px; }
        input { margin: 5px; padding: 8px; width: 100%; }
        button { background: #007bff; color: white; padding: 10px; border: none; cursor: pointer; margin: 5px; }
        button:hover { background: #0056b3; }
        a { color: #007bff; text-decoration: none; }
    </style>
</head>
<body>
    <h1>Edit Student</h1>

    <form method="POST" action="/view/students/edit/<%= student._id %>">
        <label>Name:</label>
        <input name="name" value="<%= student.name %>" required />
        <br>
        <label>Roll:</label>
        <input type="number" name="roll" value="<%= student.roll %>" min="1" required />
        <br>
        <button type="submit">Save</button>
        <a href="/view/students">Cancel</a>
    </form>
</body>
</html>
